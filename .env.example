# LINE Messaging API設定
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# サーバー設定
PORT=3000

# データベース設定（以下のいずれかを設定）
DATABASE_URL=postgres://user:password@host:5432/dbname
# POSTGRES_URL=postgres://user:password@host:6543/dbname?sslmode=require
# POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/dbname?sslmode=require

# Supabase設定（Vercelデプロイ時に使用）
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# セキュリティ設定（必ず変更してください）
ADMIN_RESET_SECRET_KEY=your_strong_random_secret_key_here
MIGRATION_SECRET=your_strong_random_migration_secret_here
